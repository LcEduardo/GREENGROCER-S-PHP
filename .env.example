# Copie este arquivo para .env e ajuste conforme o banco que você vai usar.
# O .env NÃO vai para o Git.

# Qual conexão de config/database.php usar: sqlite ou pgsql.
DB_DRIVER=sqlite

# --- SQLite ---
# Sem isso, o banco fica em database/greengrocers.sqlite na raiz do projeto.
# Se for definir, use caminho ABSOLUTO (ou :memory: para um banco que só vive no processo).
# DB_DATABASE=

# --- Postgres (usado quando DB_DRIVER=pgsql) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=greengrocers
DB_USER=postgres
DB_PASSWORD=
DB_CHARSET=utf8
